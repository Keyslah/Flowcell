# Normalize line endings across Windows/Linux tools.
* text=auto

# Docs and config stay LF.
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Script types commonly edited/run on Windows stay CRLF.
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf
*.ahk text eol=crlf
*.vbs text eol=crlf

# Python and web-style source stay LF.
*.py text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.cs text eol=lf

# Binary files are never line-ending converted.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.7z binary
*.exe binary
*.dll binary
*.pdb binary
*.msi binary
